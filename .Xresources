URxvt*cursorColor:        orange
URxvt.font:               xft:Inconsolata-Regular:pixelsize=15:antialias=true:hinting=true
Xcursor.theme:            whiteglass
Xcursor.size:             14
URxvt*depth:              24
URxvt*borderless:         1
URxvt*scrollBar:          false
URxvt*saveLines:          2000
URxvt*background:         #000000
URxvt*foreground:         #36a9dc
URxvt*scrollTtyOutput:    false
URxvt*scrollWithBuffer:   true
URxvt*scrollTtyKeypress:  true
URxvt.transparent:        true
URxvt.shading:            50
*color0:                  #2E3436
*color1:                  #a40000
*color2:                  #4E9A06
*color3:                  #C4A000
*color4:                  #3465A4
*color5:                  #75507B
*color6:                  #ce5c00
*color7:                  #babdb9
*color8:                  #555753
*color9:                  #EF2929
*color10:                 #8AE234
*color11:                 #EEEEEC
*color12:                 #729FCF
*color13:                 #AD7FA8
*color14:                 #fcaf3e
*color15:                 #EEEEEC
