#include "/home/sk/.Xresources.local"
Xcursor.theme:              whiteglass
Xcursor.size:               12
Xft.dpi: 120
URxvt*geometry:             115x40
URxvt*cursorColor:          #36a9dc
URxvt*depth:                24
URxvt*borderless:           1
URxvt*scrollBar:            false
URxvt*saveLines:            20000
URxvt*background:           #1C3749
URxvt*foreground:           #D4D8D5
URxvt*scrollTtyOutput:      false
URxvt*scrollWithBuffer:     true
URxvt*scrollTtyKeypress:    true
URxvt*iso14755:             False
URxvt*transparent:          true
URxvt*shading:              90
URxvt*tintColor:            #1C3749
URxvt*perl-ext:             default,font-size,matcher
URxvt*url-launcher:         /usr/bin/chromium
URxvt*matcher.button:       C1
URxvt*matcher.pattern.1:    \\bwww\\.[\\w-]\\.[\\w./?&amp;@#-]*[\\w/-]
URxvt*keysym.C-Up:          perl:font-size:increase
URxvt*keysym.C-Down:        perl:font-size:decrease
URxvt*keysym.C-S-Up:        perl:font-size:incglobal
URxvt*keysym.C-S-Down:      perl:font-size:decglobal
URxvt.keysym.Shift-Control-V: eval:paste_clipboard
URxvt.keysym.Shift-Control-C: eval:selection_to_clipboard
