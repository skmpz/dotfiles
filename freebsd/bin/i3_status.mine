#!/bin/sh

/usr/bin/i3status | while :
do
    # read line
    # Put uptime
    uptime=`uptime | awk '{print $3 " " $4}' | sed 's/,.*//'`

    VERSION=$(freebsd-version)
    VOL=$(pactl list sinks | grep "Volume" | head -n1 | awk '{print $9}')
    TIME=$(date +'%A %d/%m/%Y %H:%M')
    LOAD=$(uptime | awk '{print $(NF-2)}' | tr -d ',')

    printf "%s\n" "FreeBSD $VERSION | CPU: $CPU% | RAM: $RAM/$TOT | up: $uptime | l: $LOAD | v: $VOL | $TIME"
    sleep 1
done
